          </material>
        </visual>
        <collision name='base_collision'>
          <geometry>
            <box><size>0.12 0.2 0.12</size></box>
          </geometry>
        </collision>
      </link>
      <joint name='world_fix' type='fixed'>
        <parent>world</parent>
        <child>solenoid_base</child>
      </joint>
      <link name='pusher_rod'>
        <pose>0 0 0 0 0 0</pose> 
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.001</iyy><iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <visual name='rod_visual'>
          <pose>0 0.1 0 1.5708 0 0</pose> 
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.3</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.8 0.1 0.1 1</ambient> 
            <diffuse>0.8 0.1 0.1 1</diffuse>
          </material>
        </visual>
        <collision name='rod_collision'>
          <pose>0 0.1 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>0.3</length>
            </cylinder>
          </geometry>
        </collision>
      </link>
      <link name='pusher_blade'>
        <pose>0 0.25 0 0 0 0</pose>
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.001</iyy><iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <visual name='blade_visual'>
          <geometry>
            <box><size>0.3 0.02 0.08</size></box>
          </geometry>
          <material>
            <ambient>0.8 0.1 0.1 1</ambient>
            <diffuse>0.8 0.1 0.1 1</diffuse>
          </material>
        </visual>
        <collision name='blade_collision'>
          <geometry>
            <box><size>0.3 0.02 0.08</size></box>
          </geometry>
        </collision>
      </link>
      <joint name='blade_joint' type='fixed'>
        <parent>pusher_rod</parent>
        <child>pusher_blade</child>
      </joint>
      <joint name='slider_joint' type='prismatic'>
        <parent>solenoid_base</parent>
        <child>pusher_rod</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>0.0</lower>
            <upper>0.15</upper>
            <effort>5000</effort>
            <velocity>20.0</velocity>
          </limit>
        </axis>
      </joint>
      <plugin name="gz::sim::systems::JointPositionController" filename="gz-sim-joint-position-controller-system">
        <joint_name>slider_joint</joint_name>
        <topic>/model/solenoid_pusher/joint/slider_joint/cmd_pos</topic>
        <p_gain>5000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>50</d_gain>
      </plugin>
      <plugin name='gz::sim::systems::TriggeredPublisher' filename='gz-sim-triggered-publisher-system'>
        <input type='gz.msgs.Int32' topic='/keyboard/keypress'>
          <match field='data'>80</match> </input>
        <output type='gz.msgs.Double' topic='/model/solenoid_pusher/joint/slider_joint/cmd_pos'>data: 0.15</output>
      </plugin>
      <plugin name='gz::sim::systems::TriggeredPublisher' filename='gz-sim-triggered-publisher-system'>
        <input type='gz.msgs.Int32' topic='/keyboard/keypress'>
          <match field='data'>112</match> </input>
        <output type='gz.msgs.Double' topic='/model/solenoid_pusher/joint/slider_joint/cmd_pos'>data: 0.15</output>
      </plugin>
      <plugin name='gz::sim::systems::TriggeredPublisher' filename='gz-sim-triggered-publisher-system'>
        <input type='gz.msgs.Int32' topic='/keyboard/keypress'>
