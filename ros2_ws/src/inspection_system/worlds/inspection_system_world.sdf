        <output type='gz.msgs.Double' topic='/model/solenoid_pusher/joint/slider_joint/cmd_pos'>data: 0.0</output>
      </plugin>
      <plugin name='gz::sim::systems::TriggeredPublisher' filename='gz-sim-triggered-publisher-system'>
