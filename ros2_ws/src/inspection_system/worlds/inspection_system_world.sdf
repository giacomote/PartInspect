    <model name='solenoid_pusher'>
      <static>false</static>
      <pose>-0.5 -0.55 0.73 0 0 0</pose>
      <link name='solenoid_base'>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <mass>5.0</mass>
          <inertia>
            <ixx>0.05</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.05</iyy><iyz>0</iyz>
            <izz>0.05</izz>
          </inertia>
        </inertial>
        <visual name='base_visual'>
          <geometry>
            <box><size>0.12 0.2 0.12</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
